<!-- From page for adding applications 
Responsibilies 
    - user input form
    - sends form data to express route
    - styled using CSS

Contains:
    - input fields
    - dropdown menus 
    - text area
    - submit button
    
-->

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">

<!DOCTYPE html>
<html>
<head>
  <title>Add Application</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>

<body>
  <div class="page-container">
    <h1>Add Internship Application</h1>
    <p class="subtitle">Track a new role, company, and application status.</p>

    <form action="/applications/add" method="POST" class="application-form">
      <label for="company">Company Name</label>
      <input type="text" id="company" name="company" placeholder="Example: Nike" required>

      <label for="companyDomain">Company Website Domain</label>
      <input type="text" id="companyDomain" name="companyDomain" placeholder="Example: nike.com" required>

      <label for="role">Role Title</label>
      <input type="text" id="role" name="role" placeholder="Example: Brand Marketing Intern" required>

      <label for="status">Status</label>
      <select id="status" name="status" required>
        <option value="Wishlist">Wishlist</option>
        <option value="Applied">Applied</option>
        <option value="Interview">Interview</option>
        <option value="Final Round">Final Round</option>
        <option value="Offer">Offer</option>
        <option value="Rejected">Rejected</option>
      </select>

      <label for="appliedDate">Date Applied</label>
      <input type="date" id="appliedDate" name="appliedDate">

      <label for="location">Location</label>
      <input type="text" id="location" name="location" placeholder="Example: New York, Remote">

      <label for="applicationLink">Application Link</label>
      <input type="url" id="applicationLink" name="applicationLink" placeholder="https://...">

      <label for="notes">Notes</label>
      <textarea id="notes" name="notes" rows="5" placeholder="Add interview notes, recruiter names, deadlines, etc."></textarea>

      <button type="submit">Save Application</button>
    </form>

    <a href="/applications" class="back-link">View All Applications</a>
  </div>
</body>
</html>