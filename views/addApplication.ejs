<!-- From page for adding applications 
Responsibilies 
    - user input form
    - sends form data to express route
    - styled using CSS

Contains:
    - input fields
    - dropdown menus 
    - text area
    - submit button
    
-->

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
<!DOCTYPE html>
<html>
<head>
  <title>Add Application</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>

<body>
  <div class="page-container">
    <h1>Add Internship Application</h1>
    <p class="subtitle">Save a company, role, status, and notes.</p>

    <form action="/applications/add" method="POST" class="application-form">
      <label>Company Name</label>
      <input type="text" name="company" placeholder="Example: Google" required>

      <label>Company Domain</label>
      <input type="text" name="companyDomain" placeholder="Example: google.com" required>

      <label>Role Title</label>
      <input type="text" name="role" placeholder="Example: Marketing Intern" required>

      <label>Status</label>
      <select name="status" required>
        <option value="Wishlist">Wishlist</option>
        <option value="Applied">Applied</option>
        <option value="Interview">Interview</option>
        <option value="Final Round">Final Round</option>
        <option value="Offer">Offer</option>
        <option value="Rejected">Rejected</option>
      </select>

      <label>Date Applied</label>
      <input type="date" name="appliedDate">

      <label>Location</label>
      <input type="text" name="location" placeholder="Example: Remote, NYC, DC">

      <label>Application Link</label>
      <input type="url" name="applicationLink" placeholder="https://...">

      <label>Notes</label>
      <textarea name="notes" rows="5" placeholder="Recruiter name, deadlines, interview notes, etc."></textarea>

      <button type="submit">Save Application</button>
    </form>

    <a href="/" class="back-link">Back Home</a>
  </div>
</body>
</html>